{
  "title": "Omega control plane",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "tags": ["omega"],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Build",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "omega_build_info", "legendFormat": "{{version}}", "refId": "A" }
      ],
      "options": { "reduceOptions": { "calcs": ["last"] }, "textMode": "name" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Domains created (total)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "expr": "omega_domains_created_total", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "SVIDs issued (total)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "expr": "sum(omega_svid_issued_total)", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Audit entries (total)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        { "expr": "sum(omega_audit_appended_total)", "refId": "A" }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "HTTP requests / s by route",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum by (route) (rate(omega_http_requests_total[1m]))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "HTTP request latency p50 / p95 / p99 (s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le) (rate(omega_http_request_duration_seconds_bucket[1m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(omega_http_request_duration_seconds_bucket[1m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(omega_http_request_duration_seconds_bucket[1m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Access decisions / s (allow vs deny)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "sum by (decision) (rate(omega_access_decisions_total[1m]))",
          "legendFormat": "{{decision}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Decision evaluation latency p50 / p99 (s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le) (rate(omega_access_decision_duration_seconds_bucket[1m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(omega_access_decision_duration_seconds_bucket[1m])))",
          "legendFormat": "p99",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "SVIDs issued / s by kind",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "sum by (kind) (rate(omega_svid_issued_total[1m]))",
          "legendFormat": "{{kind}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Audit entries / s by kind",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "sum by (kind) (rate(omega_audit_appended_total[1m]))",
          "legendFormat": "{{kind}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    }
  ]
}
